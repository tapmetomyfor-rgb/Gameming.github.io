<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FINAL GOD MODE</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:sans-serif}

:root{
--main:#0ff;
--glow:0 0 20px #0ff;
}

body{
background:radial-gradient(circle at top,#021018,#000);
color:var(--main);
height:100vh;overflow:hidden;
}

/* SCREEN */
.screen{
position:absolute;width:100%;height:100%;
display:none;flex-direction:column;
justify-content:center;align-items:center;
animation:fade .4s;
}
.active{display:flex}

/* BUTTON */
.btn{
margin:12px;
padding:20px 35px;
font-size:20px;
border:none;border-radius:25px;
background:#000;color:var(--main);
box-shadow:var(--glow), inset 0 0 12px var(--main);
width:80%;max-width:320px;
transition:.2s;
}
.btn:active{transform:scale(.9)}

/* XO */
.board{display:grid;grid-template-columns:repeat(3,110px);gap:8px}
.cell{
width:110px;height:110px;
display:flex;justify-content:center;align-items:center;
font-size:40px;background:#000;
box-shadow:var(--glow);
}

/* SLOT */
.slot{display:flex;gap:10px}
.reel{
width:70px;height:70px;
overflow:hidden;
font-size:40px;
display:flex;flex-direction:column;
align-items:center;
}

/* FLASH JACKPOT */
.flash{
position:absolute;width:100%;height:100%;
background:rgba(0,255,255,0.3);
animation:flash .5s infinite alternate;
}
@keyframes flash{to{opacity:0}}

/* PARTICLE */
.particle{
position:absolute;width:6px;height:6px;
background:var(--main);
border-radius:50%;
animation:boom .6s forwards;
}
@keyframes boom{
to{transform:translate(var(--x),var(--y));opacity:0}
}

/* LEADERBOARD */
#leaderboard{font-size:14px;text-align:center}

/* CREDIT */
.dev{position:absolute;bottom:10px;font-size:13px}
</style>
</head>

<body>

<!-- MAIN -->
<div id="main" class="screen active">
<h2>FINAL GOD MODE</h2>
<button class="btn" onclick="go('menu',event)">🎮 PLAY</button>
<button class="btn" onclick="go('rank',event)">🏆 RANK</button>
</div>

<!-- MENU -->
<div id="menu" class="screen">
<button class="btn" onclick="go('main',event)">⬅</button>
<button class="btn" onclick="go('xo',event)">❌⭕ XO</button>
<button class="btn" onclick="go('slot',event)">🎰 SLOT</button>
</div>

<!-- XO -->
<div id="xo" class="screen">
<button class="btn" onclick="go('menu',event)">⬅</button>

<select id="mode" class="btn">
<option value="easy">ง่าย</option>
<option value="normal">ปกติ</option>
<option value="hard">เทพ</option>
</select>

<div id="board" class="board"></div>
<button class="btn" onclick="reset()">🔄 รีแมตช์</button>
</div>

<!-- SLOT -->
<div id="slot" class="screen">
<button class="btn" onclick="go('menu',event)">⬅</button>
<div class="slot">
<div id="r1" class="reel"></div>
<div id="r2" class="reel"></div>
<div id="r3" class="reel"></div>
</div>
<button class="btn" onclick="spin()">SPIN</button>
</div>

<!-- RANK -->
<div id="rank" class="screen">
<button class="btn" onclick="go('main',event)">⬅</button>
<h3>🏆 Leaderboard</h3>
<div id="leaderboard"></div>
</div>

<div class="dev">พัฒนาโดย meth._15</div>

<script>

/* DATA */
let data=JSON.parse(localStorage.data||"null")||{
score:0
}

/* SAVE */
function save(){localStorage.data=JSON.stringify(data)}

/* PARTICLE */
function boom(x,y){
for(let i=0;i<20;i++){
let p=document.createElement("div")
p.className="particle"
p.style.left=x+"px"
p.style.top=y+"px"
p.style.setProperty('--x',(Math.random()*200-100)+"px")
p.style.setProperty('--y',(Math.random()*200-100)+"px")
document.body.appendChild(p)
setTimeout(()=>p.remove(),600)
}
}

/* SOUND */
function playBeep(){
let ctx=new AudioContext()
let o=ctx.createOscillator()
o.connect(ctx.destination)
o.start()
o.stop(ctx.currentTime+0.1)
}

/* NAV */
function go(id,e){
if(e){boom(e.clientX,e.clientY);playBeep();navigator.vibrate?.(50)}
document.querySelectorAll(".screen").forEach(s=>s.classList.remove("active"))
document.getElementById(id).classList.add("active")
if(id=="rank")updateRank()
}

/* XO */
let b=["","","","","","","","",""]

function draw(){
board.innerHTML=""
b.forEach((v,i)=>{
let c=document.createElement("div")
c.className="cell"
c.innerText=v
c.onclick=(e)=>{
boom(e.clientX,e.clientY);playBeep()
if(b[i])return
b[i]="X"
if(win("X")){end(true);return}
ai()
if(win("O")){end(false);return}
draw()
}
board.appendChild(c)
})
}

function ai(){
let m=mode.value
if(m=="easy"){
let e=b.map((v,i)=>v==""?i:null).filter(v=>v!=null)
b[e[Math.random()*e.length|0]]="O"
}
else if(m=="normal"){
if(Math.random()<0.5){aiRandom()}else aiHard()
}
else aiHard()
}

function aiRandom(){
let e=b.map((v,i)=>v==""?i:null).filter(v=>v!=null)
b[e[Math.random()*e.length|0]]="O"
}

function aiHard(){
let best=-Infinity,move
for(let i=0;i<9;i++){
if(!b[i]){
b[i]="O"
let score=minimax(b,0,false)
b[i]=""
if(score>best){best=score;move=i}
}
}
b[move]="O"
}

function minimax(board,depth,isMax){
if(win("O"))return 10-depth
if(win("X"))return depth-10
if(board.every(v=>v))return 0

if(isMax){
let best=-Infinity
for(let i=0;i<9;i++){
if(!board[i]){
board[i]="O"
best=Math.max(best,minimax(board,depth+1,false))
board[i]=""
}
}
return best
}else{
let best=Infinity
for(let i=0;i<9;i++){
if(!board[i]){
board[i]="X"
best=Math.min(best,minimax(board,depth+1,true))
board[i]=""
}
}
return best
}
}

function win(p){
return [[0,1,2],[3,4,5],[6,7,8],[0,4,8],[2,4,6]]
.some(w=>w.every(i=>b[i]==p))
}

function end(winState){
if(winState){alert("ชนะ");data.score+=10}
else{alert("แพ้");data.score-=5}
save()
reset()
}

function reset(){b=["","","","","","","","",""];draw()}
draw()

/* SLOT */
let icons=["🍒","🍋","⭐","💎"]

function spin(){
playBeep()
spinReel(r1)
spinReel(r2)
spinReel(r3)

setTimeout(()=>{
let a=r1.lastChild.innerText
let b=r2.lastChild.innerText
let c=r3.lastChild.innerText

if(a==b&&b==c){
data.score+=50
save()

let f=document.createElement("div")
f.className="flash"
document.body.appendChild(f)

setTimeout(()=>f.remove(),1000)

alert("💎 JACKPOT!")
}
},900)
}

function spinReel(el){
el.innerHTML=""
let i=0
let int=setInterval(()=>{
let d=document.createElement("div")
d.innerText=icons[Math.random()*4|0]
el.appendChild(d)
if(el.children.length>3)el.removeChild(el.firstChild)
i++
if(i>20)clearInterval(int)
},50)
}

/* RANK */
function updateRank(){
leaderboard.innerHTML="คะแนนของคุณ: "+data.score
}

</script>

</body>
</html>
