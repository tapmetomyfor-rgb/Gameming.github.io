<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FINAL GOD MODE</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:sans-serif}

:root{
--main:#0ff;
--glow:0 0 20px #0ff;
}

/* BODY */
body{
background:radial-gradient(circle at top,#021018,#000);
color:var(--main);
height:100vh;overflow:hidden;
}

/* HUD */
#moneyBox{position:absolute;top:10px;right:10px}
#levelBox{position:absolute;top:10px;left:10px}

/* SCREEN */
.screen{
position:absolute;width:100%;height:100%;
display:none;flex-direction:column;
justify-content:center;align-items:center;
animation:fade .4s;
}
.active{display:flex}
@keyframes fade{from{opacity:0;transform:scale(.9)}to{opacity:1}}

/* BUTTON BIG */
.btn{
margin:14px;
padding:22px 38px;
font-size:20px;
border:none;border-radius:25px;
background:#000;color:var(--main);
box-shadow:var(--glow), inset 0 0 12px var(--main);
width:80%;max-width:320px;
}
.btn:active{transform:scale(.92)}

/* MENU */
.scroll{overflow-y:auto;width:95%;max-height:70%}
.card{
background:#000;padding:15px;margin:10px;
border-radius:15px;box-shadow:var(--glow);
display:flex;justify-content:space-between;
align-items:center;
}

/* XO */
.board{display:grid;grid-template-columns:repeat(3,120px);gap:8px}
.cell{
width:120px;height:120px;
display:flex;justify-content:center;align-items:center;
font-size:45px;background:#000;
box-shadow:var(--glow);
}

/* SLOT */
.slot{display:flex;font-size:55px}
.reel{width:70px;height:70px;overflow:hidden}

/* SHOP */
.shopItem{
margin:10px;padding:15px;
background:#000;border-radius:15px;
box-shadow:var(--glow);text-align:center;
}

/* EFFECT */
.flash{
position:absolute;width:100%;height:100%;
background:rgba(0,255,255,0.2);
animation:flash .5s;
}
@keyframes flash{to{opacity:0}}

.particle{
position:absolute;width:6px;height:6px;
background:var(--main);
border-radius:50%;
animation:boom .6s forwards;
}
@keyframes boom{
to{transform:translate(var(--x),var(--y));opacity:0}
}

/* CREDIT */
.dev{
position:absolute;
bottom:10px;
font-size:13px;
text-shadow:var(--glow);
}
.dev a{color:var(--main);text-decoration:none}
</style>
</head>

<body>

<div id="moneyBox">💰100</div>
<div id="levelBox">Lv.1</div>

<!-- MAIN -->
<div id="main" class="screen active">
<div class="title">FINAL GOD MODE</div>
<button class="btn" onclick="go('menu')">🎮 PLAY</button>
<button class="btn" onclick="go('shop')">🛒 SHOP</button>
</div>

<!-- SHOP -->
<div id="shop" class="screen">
<button class="btn" onclick="go('main')">⬅</button>
<div id="shopList"></div>
</div>

<!-- MENU -->
<div id="menu" class="screen">
<button class="btn" onclick="go('main')">⬅</button>
<div class="scroll">
<div class="card">❌⭕ XO <button class="btn" onclick="go('xo')">PLAY</button></div>
<div class="card">✊✌️✋ RPS <button class="btn" onclick="go('rps')">PLAY</button></div>
<div class="card">🎰 SLOT <button class="btn" onclick="go('slot')">PLAY</button></div>
</div>
</div>

<!-- XO -->
<div id="xo" class="screen">
<button class="btn" onclick="go('menu')">⬅</button>
<div id="board" class="board"></div>
</div>

<!-- RPS -->
<div id="rps" class="screen">
<button class="btn" onclick="go('menu')">⬅</button>
<button class="btn" onclick="rps('rock')">✊</button>
<button class="btn" onclick="rps('paper')">✋</button>
<button class="btn" onclick="rps('scissor')">✌️</button>
<div id="rpsText"></div>
</div>

<!-- SLOT -->
<div id="slot" class="screen">
<button class="btn" onclick="go('menu')">⬅</button>
<div class="slot">
<div id="r1" class="reel"></div>
<div id="r2" class="reel"></div>
<div id="r3" class="reel"></div>
</div>
<button class="btn" onclick="spin()">SPIN</button>
</div>

<!-- CREDIT -->
<div class="dev">
พัฒนาโดย 
<a href="https://www.instagram.com/meth._15" target="_blank">
meth._15
</a>
</div>

<script>

/* DATA */
let data=JSON.parse(localStorage.data||"null")||{
money:100,xp:0,level:1,
theme:"cyan",owned:["cyan"],
sound:true
}

/* SAVE */
function save(){
localStorage.data=JSON.stringify(data)
updateUI()
}

/* UI */
function updateUI(){
moneyBox.innerText="💰"+data.money
data.level=Math.floor(data.xp/100)+1
levelBox.innerText="Lv."+data.level
}

/* XP */
function gainXP(v){
data.xp+=v
}

/* SOUND */
function sound(){
if(!data.sound)return
let ctx=new AudioContext()
let o=ctx.createOscillator()
o.connect(ctx.destination)
o.start()
o.stop(ctx.currentTime+0.1)
}

/* NAV */
function go(id){
sound()
document.querySelectorAll(".screen").forEach(s=>s.classList.remove("active"))
document.getElementById(id).classList.add("active")
renderShop()
}

/* SHOP */
const themes={cyan:"#0ff",red:"#f44",lime:"#0f8"}

function renderShop(){
shopList.innerHTML=""
for(let k in themes){
let owned=data.owned.includes(k)
let div=document.createElement("div")
div.className="shopItem"

div.innerHTML=`
<button class="btn" onclick="buyTheme('${k}')">
${k} ${owned?"(ใช้)":"50$"}
</button>
`
shopList.appendChild(div)
}
}

function buyTheme(k){
if(!data.owned.includes(k)){
if(data.money<50)return alert("เงินไม่พอ")
data.money-=50
data.owned.push(k)
boom()
}
data.theme=k
document.documentElement.style.setProperty('--main',themes[k])
save()
}

/* EFFECT */
function boom(){
for(let i=0;i<25;i++){
let p=document.createElement("div")
p.className="particle"
p.style.left=innerWidth/2+"px"
p.style.top=innerHeight/2+"px"
p.style.setProperty('--x',(Math.random()*200-100)+"px")
p.style.setProperty('--y',(Math.random()*200-100)+"px")
document.body.appendChild(p)
setTimeout(()=>p.remove(),600)
}
}

/* XO AI */
let b=["","","","","","","","",""]

function draw(){
board.innerHTML=""
b.forEach((v,i)=>{
let c=document.createElement("div")
c.className="cell"
c.innerText=v
c.onclick=()=>{
if(b[i])return
b[i]="X"
if(win("X")){alert("ชนะ");gainXP(20);reset()}
ai()
if(win("O")){alert("แพ้");reset()}
draw()
}
board.appendChild(c)
})
}

function ai(){
let best=-Infinity,move
for(let i=0;i<9;i++){
if(!b[i]){
b[i]="O"
let s=minimax(b,0,false)
b[i]=""
if(s>best){best=s;move=i}
}
}
b[move]="O"
}

function minimax(board,depth,isMax){
if(win("O"))return 10-depth
if(win("X"))return depth-10
if(board.every(v=>v))return 0

if(isMax){
let best=-Infinity
for(let i=0;i<9;i++){
if(!board[i]){
board[i]="O"
best=Math.max(best,minimax(board,depth+1,false))
board[i]=""
}
}
return best
}else{
let best=Infinity
for(let i=0;i<9;i++){
if(!board[i]){
board[i]="X"
best=Math.min(best,minimax(board,depth+1,true))
board[i]=""
}
}
return best
}
}

function win(p){
return [[0,1,2],[3,4,5],[6,7,8],[0,4,8],[2,4,6]]
.some(w=>w.every(i=>b[i]==p))
}

function reset(){b=["","","","","","","","",""]}
draw()

/* RPS */
function rps(p){
let arr=["rock","paper","scissor"]
let ai=arr[Math.random()*3|0]

if(p==ai)return
if((p=="rock"&&ai=="scissor")||(p=="paper"&&ai=="rock")||(p=="scissor"&&ai=="paper")){
data.money+=10;gainXP(10)
}else data.money-=5

save()
}

/* SLOT */
let icons=["🍒","🍋","⭐","💎"]

function spin(){
if(data.money<5)return
data.money-=5

spinReel(r1)
spinReel(r2)
spinReel(r3)

setTimeout(()=>{
let a=r1.lastChild.innerText
let b=r2.lastChild.innerText
let c=r3.lastChild.innerText

if(a==b&&b==c){
data.money+=100
gainXP(50)

let f=document.createElement("div")
f.className="flash"
document.body.appendChild(f)
setTimeout(()=>f.remove(),500)

alert("💎 JACKPOT!")
}

save()
},800)
}

function spinReel(el){
el.innerHTML=""
let i=0
let int=setInterval(()=>{
let d=document.createElement("div")
d.innerText=icons[Math.random()*4|0]
el.appendChild(d)
if(el.children.length>3)el.removeChild(el.firstChild)
i++
if(i>15)clearInterval(int)
},50)
}

updateUI()

</script>

</body>
</html>
