<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FINAL GOD MODE</title>

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:sans-serif}

/* THEME */
:root{
--main:#0ff;
--glow:0 0 20px #0ff;
}

/* BODY */
body{
background:radial-gradient(circle at top,#021018,#000);
color:var(--main);
height:100vh;overflow:hidden;
}

/* MONEY HUD */
#moneyBox{
position:absolute;
top:10px;right:10px;
font-size:18px;
text-shadow:var(--glow);
}

/* SCREEN */
.screen{
position:absolute;width:100%;height:100%;
display:none;flex-direction:column;
justify-content:center;align-items:center;
animation:fade .4s;
}
.active{display:flex}
@keyframes fade{from{opacity:0;transform:scale(.9)}to{opacity:1}}

/* UI */
.title{
font-size:34px;
text-shadow:var(--glow);
margin-bottom:20px;
}

.btn{
margin:12px;padding:20px 35px;
font-size:18px;
border:none;border-radius:25px;
background:#000;color:var(--main);
box-shadow:var(--glow), inset 0 0 10px var(--main);
transition:.15s;
}
.btn:active{transform:scale(.9)}

.scroll{overflow-y:auto;width:95%;max-height:70%}
.card{
background:#000;border-radius:20px;
padding:20px;margin:12px;
display:flex;justify-content:space-between;
align-items:center;
box-shadow:var(--glow);
}

.board{display:grid;grid-template-columns:repeat(3,110px);gap:8px}
.cell{
width:110px;height:110px;
display:flex;justify-content:center;align-items:center;
font-size:40px;background:#000;
box-shadow:var(--glow);
}

.slot{display:flex;font-size:60px}
.reel{width:70px;height:70px;overflow:hidden}

.shopItem{
margin:10px;padding:15px;
border-radius:15px;
background:#000;
box-shadow:var(--glow);
text-align:center;
}

.preview{
height:30px;margin:10px;border-radius:10px;
}

/* EFFECT */
.particle{
position:absolute;
width:6px;height:6px;
background:var(--main);
border-radius:50%;
pointer-events:none;
animation:boom .6s linear forwards;
}
@keyframes boom{
to{
transform:translate(var(--x),var(--y));
opacity:0;
}
}
</style>
</head>

<body>

<div id="moneyBox">💰100</div>

<!-- MAIN -->
<div id="main" class="screen active">
<div class="title">FINAL GOD MODE</div>
<button class="btn" onclick="go('menu')">🎮 PLAY</button>
<button class="btn" onclick="go('shop')">🛒 SHOP</button>
<button class="btn" onclick="go('setting')">⚙️ SETTING</button>
</div>

<!-- SETTING -->
<div id="setting" class="screen">
<button class="btn" onclick="go('main')">⬅</button>
<button class="btn" onclick="toggleSound()">🔊 SOUND</button>
</div>

<!-- SHOP -->
<div id="shop" class="screen">
<button class="btn" onclick="go('main')">⬅</button>
<div id="shopList"></div>
</div>

<!-- MENU -->
<div id="menu" class="screen">
<button class="btn" onclick="go('main')">⬅</button>
<div class="scroll">
<div class="card">❌⭕ XO <button class="btn" onclick="go('xo')">PLAY</button></div>
<div class="card">🎲 RANDOM <button class="btn" onclick="go('rps')">PLAY</button></div>
<div class="card">🎰 SLOT <button class="btn" onclick="go('slot')">PLAY</button></div>
</div>
</div>

<!-- XO -->
<div id="xo" class="screen">
<button class="btn" onclick="go('menu')">⬅</button>
<div id="board" class="board"></div>
</div>

<!-- RPS -->
<div id="rps" class="screen">
<button class="btn" onclick="go('menu')">⬅</button>
<div class="title">🎲 เขย่า</div>
<button class="btn" onclick="shake()">เขย่า</button>
<div id="rpsText"></div>
</div>

<!-- SLOT -->
<div id="slot" class="screen">
<button class="btn" onclick="go('menu')">⬅</button>
<div class="slot">
<div id="r1" class="reel"></div>
<div id="r2" class="reel"></div>
<div id="r3" class="reel"></div>
</div>
<button class="btn" onclick="spin()">SPIN</button>
</div>

<script>

/* DATA */
let data=JSON.parse(localStorage.data||"null")||{
money:100,
theme:"cyan",
owned:["cyan"],
sound:true
}

/* THEMES */
const themes={
cyan:{color:"#0ff",glow:"0 0 20px #0ff"},
red:{color:"#ff4444",glow:"0 0 20px #ff4444"},
lime:{color:"#00ff88",glow:"0 0 20px #00ff88"}
}

/* APPLY THEME */
function applyTheme(){
let t=themes[data.theme]
document.documentElement.style.setProperty('--main',t.color)
document.documentElement.style.setProperty('--glow',t.glow)
}
applyTheme()

/* SAVE */
function save(){
localStorage.data=JSON.stringify(data)
updateMoney()
}

/* MONEY UI */
function updateMoney(){
moneyBox.innerText="💰"+data.money
}
updateMoney()

/* SOUND */
function sound(){
if(!data.sound)return
let ctx=new AudioContext()
let o=ctx.createOscillator()
o.frequency.value=500
o.connect(ctx.destination)
o.start()
o.stop(ctx.currentTime+0.1)
}

/* NAV */
function go(id){
sound()
document.querySelectorAll(".screen").forEach(s=>s.classList.remove("active"))
document.getElementById(id).classList.add("active")
renderShop()
}

/* SHOP */
function renderShop(){
shopList.innerHTML=""
for(let k in themes){

let owned=data.owned.includes(k)

let div=document.createElement("div")
div.className="shopItem"

div.innerHTML=`
<div>${k.toUpperCase()}</div>
<div class="preview" style="background:${themes[k].color}"></div>
<button class="btn" onclick="preview('${k}')">PREVIEW</button>
<button class="btn" onclick="buy('${k}')">
${owned?"USE":"BUY 50"}
</button>
`

shopList.appendChild(div)
}
}

/* PREVIEW */
function preview(k){
sound()
let t=themes[k]
document.documentElement.style.setProperty('--main',t.color)
document.documentElement.style.setProperty('--glow',t.glow)
}

/* PARTICLE EFFECT */
function boom(){
for(let i=0;i<20;i++){
let p=document.createElement("div")
p.className="particle"
p.style.left=innerWidth/2+"px"
p.style.top=innerHeight/2+"px"
p.style.setProperty('--x',(Math.random()*200-100)+"px")
p.style.setProperty('--y',(Math.random()*200-100)+"px")
document.body.appendChild(p)
setTimeout(()=>p.remove(),600)
}
}

/* BUY */
function buy(k){
sound()

if(!data.owned.includes(k)){
if(data.money<50)return alert("เงินไม่พอ")
data.money-=50
data.owned.push(k)
boom()
}

data.theme=k
applyTheme()
save()
}

/* XO */
let b=["","","","","","","","",""]
function draw(){
board.innerHTML=""
b.forEach((v,i)=>{
let c=document.createElement("div")
c.className="cell"
c.innerText=v
c.onclick=()=>{
sound()
if(b[i])return
b[i]="X"
if(win("X"))return alert("ชนะ")
ai()
if(win("O"))return alert("แพ้")
draw()
}
board.appendChild(c)
})
}
function ai(){
let best=-Infinity,move
for(let i=0;i<9;i++){
if(!b[i]){
b[i]="O"
let s=minimax(b,false)
b[i]=""
if(s>best){best=s;move=i}
}
}
b[move]="O"
}
function minimax(board,isMax){
if(win("O"))return 1
if(win("X"))return -1
if(board.every(v=>v))return 0
if(isMax){
let best=-Infinity
for(let i=0;i<9;i++){
if(!board[i]){
board[i]="O"
best=Math.max(best,minimax(board,false))
board[i]=""
}
}
return best
}else{
let best=Infinity
for(let i=0;i<9;i++){
if(!board[i]){
board[i]="X"
best=Math.min(best,minimax(board,true))
board[i]=""
}
}
return best
}
}
function win(p){
return [[0,1,2],[3,4,5],[6,7,8],[0,4,8],[2,4,6]]
.some(w=>w.every(i=>b[i]==p))
}
draw()

/* RANDOM */
function shake(){
sound()
let arr=["ชนะ","แพ้","เสมอ"]
rpsText.innerText=arr[Math.random()*3|0]
}

/* SLOT */
let icons=["🍒","🍋","⭐","💎"]
function spin(){
sound()
spinReel(r1)
spinReel(r2)
spinReel(r3)
}
function spinReel(el){
el.innerHTML=""
let i=0
let int=setInterval(()=>{
let span=document.createElement("div")
span.innerText=icons[Math.random()*4|0]
el.appendChild(span)
if(el.children.length>3)el.removeChild(el.firstChild)
i++
if(i>15)clearInterval(int)
},50)
}

/* SOUND TOGGLE */
function toggleSound(){
data.sound=!data.sound
save()
}

</script>

</body>
</html>
